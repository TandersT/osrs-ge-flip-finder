# Contact string sent as User-Agent to the OSRS Wiki API (required etiquette).
# Put a reachable email or Discord handle here.
WIKI_USER_AGENT="ge-flip-finder/1.0 (contact: you@example.com)"

# Port the Fastify server listens on (serves API + built SPA in production)
PORT=3000

# Base URL of the OSRS Wiki real-time prices API
WIKI_API_BASE=https://prices.runescape.wiki/api/v1/osrs

# --- Flip math ---
# Fraction of market volume you can realistically capture per 4h window
CAPTURE_RATE=0.10
# Competitive offer offsets: buy at low+OFFSET, sell at high-OFFSET (0 disables)
OFFER_OFFSET=1

# --- Refresh / staleness (seconds) ---
# How often the client re-polls /api/items
CLIENT_REFRESH_SECONDS=60
# A price older than this is flagged "stale"
STALE_AFTER_SECONDS=1800

# --- Long-term screener ---
# Only screen items with at least this daily volume
LONGTERM_MIN_DAILY_VOLUME=5000
# How many of the most liquid items to screen with 24h timeseries
LONGTERM_MAX_ITEMS=250
